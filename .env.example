# ============================================================
# EasyJob CM - Environment Template
# Copy this file to .env.local and fill with real values.
# Never commit .env.local or production secrets.
# ============================================================

# --- Supabase (required for app runtime) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# Optional for auth redirect override in local dev
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# Required by seed scripts / server admin ops (never expose in client)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- App base URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Mobile Money sandbox (recommended true in dev) ---
MOBILE_MONEY_SANDBOX=true

# MTN MoMo
MTN_MOMO_API_KEY=sandbox_key
MTN_MOMO_API_SECRET=sandbox_secret
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=

# Orange Money
ORANGE_MONEY_API_KEY=sandbox_key
ORANGE_MONEY_MERCHANT_KEY=sandbox_secret
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay/cm/v1

# --- OAuth Google (lu par la CLI Supabase locale via supabase/config.toml) ---
# À renseigner dans .env (à la racine) pour `supabase start`.
# Côté Next.js, mettre NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false pour masquer le bouton si non configuré.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true

# --- Twilio SMS (prod uniquement, requis pour [auth.sms.twilio]) ---
# Account SID + Auth Token : https://console.twilio.com/
# Message Service SID : créer un Messaging Service avec un sender ID "EasyJob"
SUPABASE_AUTH_SMS_TWILIO_ACCOUNT_SID=
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=
SUPABASE_AUTH_SMS_TWILIO_MESSAGE_SERVICE_SID=
