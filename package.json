{
  "name": "easyjob-cm",
  "version": "0.1.6",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:reset": "npx supabase db reset --local --yes --no-seed",
    "seed": "npx tsx scripts/seed-test-data.ts",
    "bootstrap:local": "npx tsx scripts/bootstrap-local.ts",
    "pwa:icons": "pwa-asset-generator ./public/logo-source.png ./public/icons --opaque false --background transparent --icon-only --padding 0 --favicon",
    "pwa:splash": "pwa-asset-generator ./public/logo-source.png ./public/icons --background #1A0A2E --theme-color #7C3AED --padding 20% --maskable --splash-only",
    "pwa:all": "pnpm pwa:icons && pnpm pwa:splash"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.187",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "ai": "^6.0.185",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-intl": "^4.12.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "3.6.2",
    "pwa-asset-generator": "^8.1.4",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
